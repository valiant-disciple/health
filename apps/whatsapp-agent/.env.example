# ──────────────────────────────────────────────────────────────────────────
# WhatsApp biomarker bot — environment configuration
# Copy to .env (gitignored) and fill in. NEVER commit .env.
# ──────────────────────────────────────────────────────────────────────────

# Environment
ENVIRONMENT=development                 # development | staging | production
LOG_LEVEL=info
PUBLIC_BASE_URL=https://your-public-host.example.com

# ── Twilio (WhatsApp) ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ORCHESTRATOR_MODEL=gpt-4o
EXTRACTOR_MODEL=gpt-4o-mini
VISION_MODEL=gpt-4o

# ── Mistral (OCR) ─────────────────────────────────────────────────────────
MISTRAL_API_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_DB_URL=postgresql://postgres:password@db.yourproject.supabase.co:5432/postgres
SUPABASE_POOLER_URL=postgresql://postgres.yourproject:password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
SUPABASE_STORAGE_BUCKET=lab-reports

# ── Upstash Redis ─────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── Application secrets (generate with: openssl rand -hex 32) ─────────────
PHONE_HASH_PEPPER=                     # NEVER ROTATE — hashes phone numbers
PII_ENCRYPTION_KEY=                    # AES-256-GCM key (base64 32 bytes)
INTERNAL_API_KEY=                      # admin endpoints

# ── Observability (optional in dev) ───────────────────────────────────────
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

# ── Limits ────────────────────────────────────────────────────────────────
RATE_LIMIT_MSG_PER_MIN=10
RATE_LIMIT_PDFS_PER_DAY=30
RATE_LIMIT_MSG_PER_DAY=200
MAX_PDF_SIZE_MB=10
MAX_PDF_PAGES=50
DAILY_USER_SPEND_CAP_USD=1.00
GLOBAL_DAILY_SPEND_CAP_USD=50.00

# ── Behavior ──────────────────────────────────────────────────────────────
CONVERSATION_HISTORY_TURNS=10
CONVERSATION_SUMMARY_THRESHOLD=30
LAB_HISTORY_DAYS=180
PROMPT_VERSION=v1
