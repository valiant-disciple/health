# ============================================================
# health — Environment Variables
# Copy this to .env.local (Next.js) and apps/ai-service/.env
# NEVER commit .env files. Use Doppler for secrets management.
# ============================================================

# ----- Anthropic -----
ANTHROPIC_API_KEY=sk-ant-...

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # Server-side only, never expose to browser

# ----- Neo4j AuraDB -----
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=...

# ----- Qdrant Cloud -----
QDRANT_URL=https://xxxx.qdrant.io
QDRANT_API_KEY=...

# ----- Inngest -----
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=...

# ----- Redis (Upstash) -----
REDIS_URL=rediss://...
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ----- Langfuse -----
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ----- Spike API (lab OCR) -----
SPIKE_API_KEY=...

# ----- App Config -----
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000   # or Railway URL in prod
AI_SERVICE_INTERNAL_SECRET=...                     # shared secret for Next.js→FastAPI calls
